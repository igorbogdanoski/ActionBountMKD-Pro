# ─── Firebase (client-side) ───────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_DATABASE_ID=your_database_id

# ─── Google Gemini (server-side only — used by apps/web/api/generate-quest.ts) ─
# Never prefix with VITE_: that would bundle the key into the client JS.
GEMINI_API_KEY=your_gemini_key_optional

# ─── App URL (used in Stripe redirect URLs) ──────────────────────────────────
VITE_APP_URL=https://avantura.mismath.net
APP_URL=https://avantura.mismath.net

# ─── Stripe (server-side — never expose to client) ───────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ─── Stripe (client-side publishable key) ────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Firebase Admin SDK (server-side webhook only) ───────────────────────────
# Go to Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON on one line (or use JSON.stringify on it)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
