rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPERS ─────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return isAuth() && resource.data.creatorId == request.auth.uid;
    }

    function isCollaborator(resource) {
      return isAuth() &&
        resource.data.collaborators != null &&
        resource.data.collaborators.hasAny([
          { email: request.auth.token.email, role: 'editor' },
          { email: request.auth.token.email, role: 'viewer' }
        ]);
    }

    function isEditor(resource) {
      return isAuth() &&
        resource.data.collaborators != null &&
        resource.data.collaborators.hasAny([
          { email: request.auth.token.email, role: 'editor' }
        ]);
    }

    function isPublic(resource) {
      return resource.data.visibility == 'public'
          || resource.data.isPublic == true;
    }

    // Admin status comes from the `admin` custom claim on the user's ID
    // token (set via scripts/set-admin-claim.mjs), not a hardcoded UID list —
    // granting/revoking admin no longer requires editing and redeploying
    // this file plus a client config file in lockstep.
    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    function isValidQuest(data) {
      return data.keys().hasAll(['id', 'creatorId', 'title', 'visibility', 'playMode', 'sequence', 'stages', 'createdAt', 'updatedAt'])
        && data.creatorId is string
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 200
        && data.visibility in ['public', 'secret']
        && data.playMode in ['singleplayer', 'multiplayer']
        && data.sequence in ['fixed', 'random', 'selectable']
        && data.stages is list
        && data.stages.size() <= 100;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['questId', 'playerName', 'points', 'completedAt'])
        && data.questId is string
        && (!('attemptId' in data) || (data.attemptId is string
          && data.attemptId.size() >= 1
          && data.attemptId.size() <= 128))
        && (!('studentId' in data) || (data.studentId is string
          && data.studentId.size() >= 1
          && data.studentId.size() <= 128))
        && data.playerName is string
        && data.playerName.size() >= 1
        && data.playerName.size() <= 100
        && data.points is number
        && data.points >= 0
        && (!('submissions' in data) || (data.submissions is list && data.submissions.size() <= 30))
        && (!('quizAnswers' in data) || (data.quizAnswers is list && data.quizAnswers.size() <= 100))
        // grades are only ever written by the teacher via the dedicated
        // update rule below — a player's initial create must never include them.
        && !('grades' in data)
        && !('approvedAt' in data)
        && !('approvedBy' in data);
    }

    // A rubric grade update may only touch `grades` (append/replace the
    // teacher's scores) and `points` (recomputed total after grading).
    function isValidGradeUpdate(before, after) {
      return after.diff(before).affectedKeys().hasOnly(['grades', 'points'])
        && after.grades is list
        && after.grades.size() <= 30
        && after.points is number
        && after.points >= 0;
    }

    // ─── QUESTS ──────────────────────────────────────────────────────────────
    match /quests/{questId} {
      // Public quests visible to all; private only to owner/collaborators
      allow read: if isPublic(resource)
                  || isOwner(resource)
                  || isCollaborator(resource);

      // Authenticated users can create their own quests
      allow create: if isAuth()
                    && request.resource.data.creatorId == request.auth.uid
                    && isValidQuest(request.resource.data);

      // Owner or editor collaborators can update
      allow update: if (isOwner(resource) || isEditor(resource))
                    && request.resource.data.creatorId == resource.data.creatorId
                    && isValidQuest(request.resource.data);

      // Only the owner can delete
      allow delete: if isOwner(resource);
    }

    // Does the given quest belong to the current user? Used to scope results/
    // feedback reads to the quest's own creator instead of any authed user.
    function ownsQuest(questId) {
      return isAuth() &&
        get(/databases/$(database)/documents/quests/$(questId)).data.creatorId == request.auth.uid;
    }

    // ─── QUEST RESULTS ────────────────────────────────────────────────────────
    match /quest_results/{resultId} {
      // Players submit results without auth (mobile player flow)
      allow create: if isValidResult(request.resource.data);

      // Only the quest's own creator can read its results (analytics dashboard)
      allow read: if ownsQuest(resource.data.questId);

      // Only the quest owner may grade a submission (rubric review screen),
      // and only by touching grades/points — everything else is immutable.
      allow update: if request.resource.data == resource.data
                    || (ownsQuest(resource.data.questId)
                      && isValidGradeUpdate(resource.data, request.resource.data));

      allow delete: if false;
    }

    // ─── QUEST FEEDBACK ───────────────────────────────────────────────────────
    match /quest_feedback/{feedbackId} {
      allow create: if request.resource.data.keys().hasAll(['questId', 'playerName', 'comment', 'createdAt'])
                    && request.resource.data.comment.size() <= 1000;
      allow read: if ownsQuest(resource.data.questId);
      allow update, delete: if false;
    }

    // ─── USER SETTINGS ────────────────────────────────────────────────────────
    match /user_settings/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── USER PROFILES (за SaaS plan/subscription) ────────────────────────────
    match /user_profiles/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuth() && request.auth.uid == userId;
      // Users can update their own profile except plan/subscriptionId (admin-only fields)
      allow update: if isAuth() && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscriptionId']);
      // Admin can update any user profile including plan
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── PAYMENT REQUESTS ─────────────────────────────────────────────────────
    function isValidPaymentRequest(data) {
      return data.keys().hasOnly(['userId', 'userEmail', 'displayName', 'planId', 'method', 'amountMkd', 'transactionRef', 'note', 'status', 'createdAt'])
        && data.keys().hasAll(['userId', 'userEmail', 'displayName', 'planId', 'method', 'amountMkd', 'transactionRef', 'status', 'createdAt'])
        && data.planId in ['starter', 'pro', 'enterprise']
        && data.method in ['paypal', 'bank']
        && data.amountMkd is number
        && data.amountMkd > 0
        && data.amountMkd <= 100000
        && data.transactionRef is string
        && data.transactionRef.size() <= 200
        && data.userEmail is string
        && data.displayName is string
        && data.displayName.size() <= 200
        // Every request must start pending — only isAdmin() can flip status via update.
        && data.status == 'pending';
    }

    match /payment_requests/{reqId} {
      // Authenticated user can submit their own payment request
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && isValidPaymentRequest(request.resource.data);
      // Admin can read any request (approve/reject queue); a user can read
      // only their own (so Pricing can show "your upgrade is pending review"
      // without exposing other teachers' payment data) — the query must
      // filter on userId == auth.uid for this to satisfy the rule on list.
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      // Only admin can update (approve/reject)
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── TEMPLATES ────────────────────────────────────────────────────────────
    match /templates/{templateId} {
      // Public approved templates readable by everyone (no auth needed for template library)
      allow read: if true;
      // Only admin can create/update/delete templates
      allow write: if isAdmin();
    }

    // ─── CLASS GROUPS (Phase 7D-3) ─────────────────────────────────────────────
    function isValidGroup(data) {
      return data.keys().hasAll(['id', 'ownerId', 'name', 'students', 'createdAt', 'updatedAt'])
        && data.ownerId is string
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 80
        && data.students is list
        && data.students.size() <= 60;
    }

    match /class_groups/{groupId} {
      // Only the owning teacher can read their groups (contains student names)
      allow read: if isAuth() && resource.data.ownerId == request.auth.uid;

      allow create: if isAuth()
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidGroup(request.resource.data);

      allow update: if isAuth()
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId
                    && isValidGroup(request.resource.data);

      allow delete: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // ─── GAME SESSIONS (Real-time collaboration, Phase 5A) ─────────────────────
    function isSessionHost(resource) {
      return isAuth() && resource.data.hostId == request.auth.uid;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'questId', 'hostId', 'players', 'status', 'mode', 'currentStageIndex', 'stageCount', 'createdAt'])
        && data.hostId is string
        && data.questId is string
        && data.status in ['waiting', 'active', 'finished']
        && data.mode in ['free', 'broadcast']
        && data.players is list
        && data.players.size() <= 500;
    }

    match /game_sessions/{code} {
      // Players join without auth by fetching a single session by its known
      // code (get) — but the collection must never be enumerable (list),
      // since that would expose every session's roster of student names.
      allow get: if true;
      allow list: if false;

      // Only an authenticated host can create their own session
      allow create: if isAuth()
                    && request.resource.data.hostId == request.auth.uid
                    && isValidSession(request.resource.data);

      // Host has full control; anonymous players may only touch the roster
      allow update: if (isSessionHost(resource)
                        && isValidSession(request.resource.data)
                        && request.resource.data.hostId == resource.data.hostId)
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'updatedAt'])
                        && request.resource.data.players is list
                        && request.resource.data.players.size() <= 500);

      // Only the host can delete the session
      allow delete: if isSessionHost(resource);
    }

    // ─── DENY EVERYTHING ELSE ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
