rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── HELPERS ─────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    // ─── USER UPLOADS ────────────────────────────────────────────────────────
    // Paths: covers/{uid}/..., stages/{uid}/..., uploads/{uid}/...
    // Images are publicly readable (shown to players); only the owner can write.
    match /{folder}/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId);
    }

    // ─── STUDENT SUBMISSIONS (MISSION/SURVEY rubric grading) ──────────────────
    // Players are frequently unauthenticated (public play links, live sessions),
    // so this path can't be owner-gated like the uploads above — scoped instead
    // by path, size and content-type. Readable via its unguessable download-URL
    // token only, same trust model as every other path in this file.
    match /submissions/{questId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*|audio/.*');
      allow delete: if false;
    }

    // ─── DENY EVERYTHING ELSE ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
